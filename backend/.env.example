API_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
AUTH_SECRET=change-this-to-a-long-random-string
# Local MongoDB is the primary database.
MONGODB_URI=mongodb://127.0.0.1:27017
# Optional explicit primary database override.
PRIMARY_MONGODB_URI=
# Local-first offline mode: write to local first, then sync to Atlas in the background.
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017
ATLAS_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/barcen?retryWrites=true&w=majority&appName=barcen
ENABLE_ATLAS_SYNC=true
SYNC_INTERVAL_MS=30000
MONGODB_DB=barcen
