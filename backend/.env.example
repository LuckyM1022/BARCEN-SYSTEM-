API_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
AUTH_SECRET=change-this-to-a-long-random-string
# Simplest setup for another laptop: put your Atlas connection string here.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/barcen?retryWrites=true&w=majority&appName=barcen
# Optional explicit primary database override.
PRIMARY_MONGODB_URI=
# Optional local-first plus Atlas-sync setup.
LOCAL_MONGODB_URI=
ATLAS_MONGODB_URI=
ENABLE_ATLAS_SYNC=false
SYNC_INTERVAL_MS=30000
MONGODB_DB=barcen
